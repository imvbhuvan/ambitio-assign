# --- Required ---
# OpenAI API key. Used for parsing, judging, why_match generation, and embeddings.
OPENAI_API_KEY=your-openai-api-key-here

# Email for the OpenAlex "polite pool". Any valid address you control.
# Sent as mailto= on every OpenAlex request. No registration required.
OPENALEX_MAILTO=you@example.com

# --- Optional tuning (sensible defaults in src/config.py) ---
# MODEL_PARSER=gpt-5.4-mini
# MODEL_JUDGE=gpt-5.4-mini
# MODEL_WRITER=gpt-5.4-mini
# MODEL_EMBED=text-embedding-3-small
# LLM_MAX_RPM=0          # >0 paces all chat calls under a tier rate limit
# JUDGE_CONCURRENCY=20
# WHY_MATCH_CONCURRENCY=20
